# ── Local Development (H2 in-memory, no setup needed) ─────────────────
# These defaults are already in application.properties
# Just run: cd backend && mvn spring-boot:run

# ── Production (Render.com + Neon PostgreSQL) ─────────────────────────
# Set these as environment variables on Render:
SPRING_PROFILES_ACTIVE=prod
DB_URL=jdbc:postgresql://your-neon-host.neon.tech:5432/portfolio_db?sslmode=require
DB_USERNAME=your_neon_username
DB_PASSWORD=your_neon_password
JWT_SECRET=replace-with-a-long-random-secret-at-least-64-characters-long
JWT_EXPIRATION_MINUTES=480
UPLOAD_DIR=/app/uploads
PORT=8081
